# EBURON AI VEP runtime configuration.
# Copy this file to .env.local for local development.

# Required: Gemini Live API key used by the browser voice assistant runtime.
# Keep real keys in .env.local or your deployment secret store.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Required: documents that this app runtime is whitelisted to use configured
# LLM providers for EBURON AI voice, persona, context, and artifact features.
VITE_LLM_USE_WHITELISTED="true"
VITE_LLM_BRAND_NAME="EBURON AI"

# Public product and default persona labels.
VITE_PRODUCT_NAME="VEP"
VITE_PRODUCT_FULL_NAME="Virtual Employee Persona"
VITE_DEFAULT_PERSONA_NAME="Beatrice"
VITE_DEFAULT_BOSS_NAME="Jo Lernout"
VITE_EBURON_LOGO_URL="https://eburon.ai/icon-eburon.svg"

# Optional: public URL where the app is hosted.
# Used for self-referential links, OAuth callbacks, and deployment metadata.
APP_URL="MY_APP_URL"
